<UserControl x:Class="GarageFlow.Wpf.Views.ReminderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Herinneringen" FontSize="26" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- Create form -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><Label Content="Type"/><ComboBox ItemsSource="{Binding ReminderTypes}" SelectedItem="{Binding ReminderType}"/></StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8"><Label Content="Datum"/><DatePicker SelectedDate="{Binding ReminderDate}"/></StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8"><Label Content="Klant *"/><ComboBox ItemsSource="{Binding Customers}" SelectedValue="{Binding SelectedCustomerId}" SelectedValuePath="Id" DisplayMemberPath="DisplayName"/></StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,8,8"><Label Content="Bericht *"/><TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8"><Label Content="Voertuig"/><ComboBox ItemsSource="{Binding Vehicles}" SelectedValue="{Binding SelectedVehicleId}" SelectedValuePath="Id" DisplayMemberPath="PlateNumberOriginal"/></StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Aanmaken" Command="{Binding CreateCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"/>
                    <Button Content="Markeer als verzonden" Command="{Binding MarkAsSentCommand}" Style="{StaticResource AccentButton}" Margin="0,0,6,0"/>
                    <Button Content="Annuleren" Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}" Margin="0,0,6,0"/>
                    <Border Background="#E3F2FD" CornerRadius="4" Padding="2" Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="E-mail verzenden" Command="{Binding SendEmailCommand}" Style="{StaticResource PrimaryButton}" Background="#1565C0" Margin="0,0,6,0" IsEnabled="{Binding EmailConfigured}"/>
                            <Button Content="Toevoegen aan agenda" Command="{Binding AddToCalendarCommand}" Style="{StaticResource PrimaryButton}" Background="#0D47A1" Margin="0,0,6,0"/>
                            <Button Content="Agenda verbinden" Command="{Binding ConnectCalendarCommand}" Style="{StaticResource PrimaryButton}" Background="#78909C" Visibility="{Binding CalendarConfigured, Converter={StaticResource InvertBoolToVisConverter}}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" Margin="0,2,0,0"/>
            </Grid>
        </Border>

        <!-- Integration status -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                        Background="{Binding EmailConfigured, Converter={StaticResource BoolToColorConverter}, FallbackValue=#FFEBEE}">
                    <TextBlock FontSize="11">
                        <Run Text="E-mail (Resend): "/>
                        <Run Text="{Binding EmailConfigured, Mode=OneWay, Converter={StaticResource BoolToStatusConverter}, FallbackValue=Niet geconfigureerd}"/>
                    </TextBlock>
                </Border>
                <Border CornerRadius="4" Padding="8,4"
                        Background="{Binding CalendarConfigured, Converter={StaticResource BoolToColorConverter}, FallbackValue=#FFEBEE}">
                    <TextBlock FontSize="11">
                        <Run Text="Google Calendar: "/>
                        <Run Text="{Binding CalendarConfigured, Mode=OneWay, Converter={StaticResource BoolToStatusConverter}, FallbackValue=Niet geconfigureerd}"/>
                    </TextBlock>
                </Border>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Reminders}" SelectedItem="{Binding SelectedReminder}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Type" Binding="{Binding ReminderType}" Width="120"/>
                <DataGridTextColumn Header="Klant" Binding="{Binding CustomerName}" Width="*"/>
                <DataGridTextColumn Header="Kenteken" Binding="{Binding VehiclePlate}" Width="100"/>
                <DataGridTextColumn Header="Bericht" Binding="{Binding Message}" Width="*"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding ReminderDate, StringFormat=dd-MM-yyyy}" Width="100"/>
                <DataGridTextColumn Header="Kanaal" Binding="{Binding SendMethod}" Width="80"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
