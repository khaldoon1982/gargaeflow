<UserControl x:Class="GarageFlow.Wpf.Views.VehicleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Voertuigen" FontSize="26" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- Search by Kenteken -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,8,0"/>
                <Button Content="Zoeken op kenteken" Command="{Binding SearchByPlateCommand}" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><Label Content="Kenteken *"/><TextBox Text="{Binding PlateNumber, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8"><Label Content="Merk *"/><TextBox Text="{Binding Brand, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8"><Label Content="Model *"/><TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8"><Label Content="Bouwjaar"/><TextBox Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,8"><Label Content="Brandstof"/><ComboBox ItemsSource="{Binding FuelTypes}" SelectedItem="{Binding FuelType}"/></StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8"><Label Content="Transmissie"/><ComboBox ItemsSource="{Binding TransmissionTypes}" SelectedItem="{Binding TransmissionType}"/></StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8"><Label Content="Km stand"/><TextBox Text="{Binding Mileage, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,8,8"><Label Content="Kleur"/><TextBox Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,8"><Label Content="Klant *"/><ComboBox ItemsSource="{Binding Customers}" SelectedValue="{Binding SelectedCustomerId}" SelectedValuePath="Id" DisplayMemberPath="DisplayName"/></StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="{Binding IsEditing, Converter={StaticResource BoolToSaveTextConverter}}" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Bewerken" Command="{Binding EditCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                    <Button Content="Verwijderen" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                    <Button Content="Annuleren" Command="{Binding ClearFormCommand}" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kenteken" Binding="{Binding PlateNumberOriginal}" Width="100"/>
                <DataGridTextColumn Header="Merk" Binding="{Binding Brand}" Width="100"/>
                <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="100"/>
                <DataGridTextColumn Header="Bouwjaar" Binding="{Binding Year}" Width="70"/>
                <DataGridTextColumn Header="Brandstof" Binding="{Binding FuelType}" Width="80"/>
                <DataGridTextColumn Header="Km stand" Binding="{Binding Mileage}" Width="80"/>
                <DataGridTextColumn Header="Klant" Binding="{Binding CustomerName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
