<UserControl x:Class="GarageFlow.Wpf.Views.MaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Onderhoud" FontSize="26" FontWeight="Bold" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><Label Content="Type onderhoud *"/><TextBox Text="{Binding ServiceType, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8"><Label Content="Datum *"/><DatePicker SelectedDate="{Binding ServiceDate}"/></StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8"><Label Content="Voertuig *"/><ComboBox ItemsSource="{Binding Vehicles}" SelectedValue="{Binding SelectedVehicleId}" SelectedValuePath="Id" DisplayMemberPath="PlateNumberOriginal"/></StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8"><Label Content="Beschrijving *"/><TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,8"><Label Content="Monteur"/><TextBox Text="{Binding TechnicianName, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8"><Label Content="Km stand"/><TextBox Text="{Binding MileageAtService, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8"><Label Content="Arbeidskosten (€)"/><TextBox Text="{Binding LaborCost, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/></StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,8,8"><Label Content="Onderdeelkosten (€)"/><TextBox Text="{Binding PartsCost, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/></StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,8"><Label Content="Status"/><ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}" IsEnabled="{Binding IsEditing}"/></StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="{Binding IsEditing, Converter={StaticResource BoolToSaveTextConverter}}" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Bewerken" Command="{Binding EditCommand}" Style="{StaticResource AccentButton}" Margin="0,0,8,0"/>
                    <Button Content="Verwijderen" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                    <Button Content="Annuleren" Command="{Binding ClearFormCommand}" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Records}" SelectedItem="{Binding SelectedRecord}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kenteken" Binding="{Binding VehiclePlate}" Width="100"/>
                <DataGridTextColumn Header="Type" Binding="{Binding ServiceType}" Width="120"/>
                <DataGridTextColumn Header="Beschrijving" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding ServiceDate, StringFormat=dd-MM-yyyy}" Width="100"/>
                <DataGridTextColumn Header="Monteur" Binding="{Binding TechnicianName}" Width="120"/>
                <DataGridTextColumn Header="Kosten" Binding="{Binding TotalCost, StringFormat=€{0:F2}}" Width="80"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
