<UserControl x:Class="GarageFlow.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600">
            <TextBlock Text="Instellingen" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Bedrijfsgegevens" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Label Content="Bedrijfsnaam"/><TextBox Text="{Binding WorkshopName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <Label Content="Telefoonnummer"/><TextBox Text="{Binding WorkshopPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <Label Content="Adres"/><TextBox Text="{Binding WorkshopAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Logo" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Text="{Binding LogoPath, UpdateSourceTrigger=PropertyChanged}" Width="350" Margin="0,0,8,0"/>
                        <Button Content="Bladeren..." Command="{Binding BrowseLogoCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                    <Image Source="{Binding LogoPath}" MaxHeight="80" MaxWidth="200" HorizontalAlignment="Left"
                           Visibility="{Binding LogoPath, Converter={StaticResource NullToCollapsedConverter}}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Herinneringen &amp; Back-up" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Label Content="Herinnering voorloop (dagen)"/><TextBox Text="{Binding ReminderLeadDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <Label Content="Back-up map"/><TextBox Text="{Binding BackupFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                </StackPanel>
            </Border>

            <Button Content="Opslaan" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
