<Window x:Class="GarageFlow.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GarageFlow.Wpf.Views"
        xmlns:vm="clr-namespace:GarageFlow.Wpf.ViewModels"
        Title="{Binding Title}" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo + Title -->
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,10">
                    <Image Source="{Binding LogoPath}" MaxHeight="50" MaxWidth="150" Margin="0,0,0,8"
                           Visibility="{Binding LogoPath, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed}"/>
                    <TextBlock Text="{Binding WorkshopName}" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentUser.FullName}" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Background="#37474F" Margin="16,4"/>

                <!-- Logout at bottom -->
                <Button DockPanel.Dock="Bottom" Content="Uitloggen" Command="{Binding LogoutCommand}" Style="{StaticResource NavButton}" Margin="0,0,0,16"/>
                <Separator DockPanel.Dock="Bottom" Background="#37474F" Margin="16,4"/>

                <!-- Navigation -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Button Content="&#x1F4CA;  Dashboard" Command="{Binding NavigateToDashboardCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="&#x1F465;  Klanten" Command="{Binding NavigateToCustomersCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="&#x1F697;  Voertuigen" Command="{Binding NavigateToVehiclesCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="&#x1F527;  Onderhoud" Command="{Binding NavigateToMaintenanceCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="&#x1F50D;  Keuringen" Command="{Binding NavigateToInspectionsCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="&#x1F514;  Herinneringen" Command="{Binding NavigateToRemindersCommand}" Style="{StaticResource NavButton}"/>
                        <Separator Background="#37474F" Margin="16,8"/>
                        <Button Content="&#x2699;  Instellingen" Command="{Binding NavigateToSettingsCommand}" Style="{StaticResource NavButton}"/>
                        <Button Content="&#x1F4BE;  Back-up" Command="{Binding NavigateToBackupCommand}" Style="{StaticResource NavButton}"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="20">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView/></DataTemplate>
                <DataTemplate DataType="{x:Type vm:CustomerViewModel}"><views:CustomerView/></DataTemplate>
                <DataTemplate DataType="{x:Type vm:VehicleViewModel}"><views:VehicleView/></DataTemplate>
                <DataTemplate DataType="{x:Type vm:MaintenanceViewModel}"><views:MaintenanceView/></DataTemplate>
                <DataTemplate DataType="{x:Type vm:InspectionViewModel}"><views:InspectionView/></DataTemplate>
                <DataTemplate DataType="{x:Type vm:ReminderViewModel}"><views:ReminderView/></DataTemplate>
<DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
                <DataTemplate DataType="{x:Type vm:BackupViewModel}"><views:BackupView/></DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
