<UserControl x:Class="GarageFlow.Wpf.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:GarageFlow.Domain.Enums;assembly=GarageFlow.Domain">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.28*" MinWidth="260"/>
            <ColumnDefinition Width="0.72*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Klantenoverzicht -->
        <Border Grid.Column="0" Background="{StaticResource CardBrush}" Margin="0,0,10,0" CornerRadius="8" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Klantenoverzicht" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                <!-- Search -->
                <TextBox DockPanel.Dock="Top" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Zoeken" Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="12" Margin="0,0,4,0"/>
                    <Button Content="Vernieuwen" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="12" Margin="0,0,4,0" Background="{StaticResource InfoBrush}"/>
                    <Button Content="Nieuwe klant" Command="{Binding NewCustomerCommand}" Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="12" Background="{StaticResource AccentBrush}"/>
                </StackPanel>

                <!-- Customer List -->
                <ListBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="3" Padding="5,1" Margin="0,2,6,0">
                                            <TextBlock Text="{Binding CustomerType}" FontSize="10" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding PhoneNumber}" FontSize="11" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text=" • " FontSize="11" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding VehicleCount, StringFormat={}{0} voertuig(en)}" FontSize="11" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- RIGHT: Klantdetail -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CustomerNumber}" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="4" Padding="8,2" Margin="0,0,8,0">
                                <TextBlock Text="{Binding CustomerType}" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                            </Border>
                            <TextBlock Text="{Binding PhoneNumber}" FontSize="12" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding CustomerVehicles.Count, StringFormat={}{0} voertuig(en)}" FontSize="12" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Financial Summary -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10" Visibility="{Binding IsNewCustomer, Converter={StaticResource InvertBoolToVisConverter}}">
                    <WrapPanel>
                        <Border Background="#E8F5E9" CornerRadius="6" Padding="14,8" Margin="0,0,10,4">
                            <StackPanel>
                                <TextBlock Text="Totale besteding" FontSize="10" Foreground="{StaticResource SubtextBrush}"/>
                                <TextBlock Text="{Binding CustomerTotalSpent, StringFormat=€{0:N2}}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#E3F2FD" CornerRadius="6" Padding="14,8" Margin="0,0,10,4">
                            <StackPanel>
                                <TextBlock Text="Totaal onderhoud" FontSize="10" Foreground="{StaticResource SubtextBrush}"/>
                                <TextBlock Text="{Binding CustomerTotalServices}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource InfoBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFF3E0" CornerRadius="6" Padding="14,8" Margin="0,0,10,4">
                            <StackPanel>
                                <TextBlock Text="Eerste bezoek" FontSize="10" Foreground="{StaticResource SubtextBrush}"/>
                                <TextBlock Text="{Binding CustomerFirstVisit, StringFormat=dd-MM-yyyy, TargetNullValue=—}" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFF3E0" CornerRadius="6" Padding="14,8" Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="Laatste bezoek" FontSize="10" Foreground="{StaticResource SubtextBrush}"/>
                                <TextBlock Text="{Binding CustomerLastVisit, StringFormat=dd-MM-yyyy, TargetNullValue=—}" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Border>

                <!-- Klanttype -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Klanttype" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Particulier" IsChecked="{Binding CustomerType, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:CustomerType.Private}}" Margin="0,0,20,0" IsEnabled="{Binding IsEditing}"/>
                            <RadioButton Content="Zakelijk" IsChecked="{Binding CustomerType, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static enums:CustomerType.Business}}" IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Klantgegevens -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Klantgegevens" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                            <!-- Private fields -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Visibility="{Binding IsBusiness, Converter={StaticResource InvertBoolToVisConverter}}">
                                <Label Content="Voornaam *"/><TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" Visibility="{Binding IsBusiness, Converter={StaticResource InvertBoolToVisConverter}}">
                                <Label Content="Achternaam *"/><TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/>
                            </StackPanel>

                            <!-- Business fields -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Visibility="{Binding IsBusiness, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Label Content="Bedrijfsnaam *"/><TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" Visibility="{Binding IsBusiness, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Label Content="Contactpersoon"/><TextBox Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8" Visibility="{Binding IsBusiness, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Label Content="Afdeling"/><TextBox Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Contactgegevens -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Contactgegevens" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0"><Label Content="Telefoonnummer *"/><TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0"><Label Content="WhatsApp"/><TextBox Text="{Binding WhatsAppNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Column="2"><Label Content="E-mailadres"/><TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Adresgegevens -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Adresgegevens" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><Label Content="Straat"/><TextBox Text="{Binding Street, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8"><Label Content="Huisnummer"/><TextBox Text="{Binding HouseNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8"><Label Content="Toevoeging"/><TextBox Text="{Binding HouseNumberAddition, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"><Label Content="Postcode"/><TextBox Text="{Binding PostalCode, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"><Label Content="Plaats"/><TextBox Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2"><Label Content="Land"/><TextBox Text="{Binding Country, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Zakelijke gegevens (only Business) -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10" Visibility="{Binding IsBusiness, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Zakelijke gegevens" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><Label Content="KvK-nummer"/><TextBox Text="{Binding ChamberOfCommerceNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8"><Label Content="BTW-nummer"/><TextBox Text="{Binding VATNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8"><Label Content="Betalingstermijn"/><ComboBox ItemsSource="{Binding PaymentTerms}" SelectedItem="{Binding PaymentTerm}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"><Label Content="Factuur e-mail"/><TextBox Text="{Binding BillingEmail, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"><Label Content="Debiteurennummer"/><TextBox Text="{Binding DebtorNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2"><Label Content="Wagenparkbeheerder"/><TextBox Text="{Binding FleetManager, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}"/></StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Notities -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Notities" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditing}" TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>
                    </StackPanel>
                </Border>

                <!-- Action buttons -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Opslaan" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Button Content="Bewerken" Command="{Binding EditCommand}" Style="{StaticResource AccentButton}" Margin="0,0,6,0"/>
                            <Button Content="Archiveren" Command="{Binding ArchiveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" Background="#78909C"/>
                            <Button Content="Verwijderen" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="0,0,6,0"/>
                            <Button Content="Annuleren" Command="{Binding CancelCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,0" Background="#9E9E9E" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- TABS -->
                <TabControl Margin="0,0,0,10" MinHeight="300">
                    <!-- Voertuigen -->
                    <TabItem Header="Voertuigen">
                        <StackPanel Margin="8">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Voertuig toevoegen" Command="{Binding OpenAddVehicleCommand}" Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                                <Button Content="Voertuig bewerken" Command="{Binding OpenEditVehicleCommand}" Style="{StaticResource AccentButton}" Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                                <Button Content="Voertuig verwijderen" Command="{Binding DeleteVehicleCommand}" Style="{StaticResource DangerButton}" Padding="12,6" FontSize="12"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding CustomerVehicles}" SelectedItem="{Binding SelectedVehicle}" MaxHeight="250">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kenteken" Binding="{Binding PlateNumberOriginal}" Width="100"/>
                                    <DataGridTextColumn Header="Merk" Binding="{Binding Brand}" Width="90"/>
                                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="90"/>
                                    <DataGridTextColumn Header="Bouwjaar" Binding="{Binding Year}" Width="70"/>
                                    <DataGridTextColumn Header="Km-stand" Binding="{Binding Mileage}" Width="80"/>
                                    <DataGridTextColumn Header="Brandstof" Binding="{Binding FuelType}" Width="80"/>
                                    <DataGridTextColumn Header="APK vervalt" Binding="{Binding InspectionExpiryDate, StringFormat=dd-MM-yyyy}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </TabItem>

                    <!-- Onderhoud -->
                    <TabItem Header="Onderhoud">
                        <StackPanel Margin="8">
                            <WrapPanel Margin="0,0,0,8">
                                <Border Background="#E8F5E9" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                                    <TextBlock FontSize="12"><Run Text="Totaal: " Foreground="{StaticResource SubtextBrush}"/><Run Text="{Binding CustomerTotalSpent, StringFormat=€{0:N2}, Mode=OneWay}" FontWeight="Bold"/></TextBlock>
                                </Border>
                                <Border Background="#E3F2FD" CornerRadius="4" Padding="10,4">
                                    <TextBlock FontSize="12"><Run Text="Registraties: " Foreground="{StaticResource SubtextBrush}"/><Run Text="{Binding CustomerTotalServices, Mode=OneWay}" FontWeight="Bold"/></TextBlock>
                                </Border>
                            </WrapPanel>
                            <DataGrid ItemsSource="{Binding CustomerMaintenance}" MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Datum" Binding="{Binding ServiceDate, StringFormat=dd-MM-yyyy}" Width="90"/>
                                    <DataGridTextColumn Header="Kenteken" Binding="{Binding VehiclePlate}" Width="90"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding ServiceType}" Width="100"/>
                                    <DataGridTextColumn Header="Beschrijving" Binding="{Binding Description}" Width="*"/>
                                    <DataGridTextColumn Header="Monteur" Binding="{Binding TechnicianName}" Width="100"/>
                                    <DataGridTextColumn Header="Arbeid" Binding="{Binding LaborCost, StringFormat=€{0:F2}}" Width="70"/>
                                    <DataGridTextColumn Header="Onderdelen" Binding="{Binding PartsCost, StringFormat=€{0:F2}}" Width="80"/>
                                    <DataGridTextColumn Header="Totaal" Binding="{Binding TotalCost, StringFormat=€{0:F2}}" Width="70"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </TabItem>

                    <!-- Keuringen -->
                    <TabItem Header="Keuringen">
                        <DataGrid ItemsSource="{Binding CustomerInspections}" Margin="8" MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kenteken" Binding="{Binding VehiclePlate}" Width="90"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding InspectionType}" Width="90"/>
                                <DataGridTextColumn Header="Keuringsdatum" Binding="{Binding InspectionDate, StringFormat=dd-MM-yyyy}" Width="110"/>
                                <DataGridTextColumn Header="Vervaldatum" Binding="{Binding ExpiryDate, StringFormat=dd-MM-yyyy}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- Herinneringen -->
                    <TabItem Header="Herinneringen">
                        <DataGrid ItemsSource="{Binding CustomerReminders}" Margin="8" MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Datum" Binding="{Binding ReminderDate, StringFormat=dd-MM-yyyy}" Width="90"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding ReminderType}" Width="110"/>
                                <DataGridTextColumn Header="Kenteken" Binding="{Binding VehiclePlate}" Width="90"/>
                                <DataGridTextColumn Header="Bericht" Binding="{Binding Message}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Vehicle Dialog Overlay -->
        <Border Grid.ColumnSpan="2" Background="#80000000" Visibility="{Binding IsVehicleDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="White" CornerRadius="10" Padding="24" MaxWidth="600" MaxHeight="550" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding IsVehicleEditing, Converter={StaticResource BoolToSaveTextConverter}, StringFormat=Voertuig {0}}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><Label Content="Kenteken *"/><TextBox Text="{Binding VehiclePlateNumber, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8"><Label Content="Merk *"/><TextBox Text="{Binding VehicleBrand, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8"><Label Content="Model *"/><TextBox Text="{Binding VehicleModel, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8"><Label Content="Bouwjaar"/><TextBox Text="{Binding VehicleYear, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,8"><Label Content="Brandstof"/><ComboBox ItemsSource="{Binding FuelTypes}" SelectedItem="{Binding VehicleFuelType}"/></StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,8"><Label Content="Transmissie"/><ComboBox ItemsSource="{Binding TransmissionTypes}" SelectedItem="{Binding VehicleTransmissionType}"/></StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8"><Label Content="Km-stand"/><TextBox Text="{Binding VehicleMileage, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,8,8"><Label Content="Kleur"/><TextBox Text="{Binding VehicleColor, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,8"><Label Content="APK vervaldatum"/><DatePicker SelectedDate="{Binding VehicleInspectionExpiryDate}"/></StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8"><Label Content="Opmerkingen"/><TextBox Text="{Binding VehicleNotes, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding VehicleErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Opslaan" Command="{Binding SaveVehicleCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Annuleren" Command="{Binding CancelVehicleCommand}" Style="{StaticResource PrimaryButton}" Background="#9E9E9E"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
